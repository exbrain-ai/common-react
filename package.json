{
  "name": "@exbrain/common-react",
  "version": "1.0.0",
  "description": "Shared React components, utilities, and styles for React projects",
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./server": {
      "types": "./src/server/index.ts",
      "import": "./src/server/index.ts",
      "require": "./src/server/index.ts",
      "default": "./src/server/index.ts"
    },
    "./server/middleware-request-id": {
      "types": "./src/server/middleware-request-id.ts",
      "import": "./src/server/middleware-request-id.ts",
      "default": "./src/server/middleware-request-id.ts"
    },
    "./server/client-logs-ingest": {
      "types": "./src/server/client-logs-ingest.ts",
      "import": "./src/server/client-logs-ingest.ts",
      "default": "./src/server/client-logs-ingest.ts"
    },
    "./server/edge-logger": {
      "types": "./src/server/edge-logger.ts",
      "import": "./src/server/edge-logger.ts",
      "default": "./src/server/edge-logger.ts"
    },
    "./server/log-level-manager": {
      "types": "./src/server/log-level-manager.ts",
      "import": "./src/server/log-level-manager.ts",
      "default": "./src/server/log-level-manager.ts"
    },
    "./server/server-logger": {
      "types": "./src/server/server-logger.ts",
      "import": "./src/server/server-logger.ts",
      "default": "./src/server/server-logger.ts"
    },
    "./logger": {
      "types": "./dist/logger.d.ts",
      "import": "./dist/logger.esm.js",
      "require": "./dist/logger.cjs.js"
    },
    "./i18n": {
      "types": "./src/utils/i18n.ts",
      "import": "./src/utils/i18n.ts",
      "default": "./src/utils/i18n.ts"
    },
    "./request-id": {
      "types": "./src/utils/requestId.ts",
      "import": "./src/utils/requestId.ts",
      "require": "./src/utils/requestId.ts",
      "default": "./src/utils/requestId.ts"
    },
    "./styles/tokens.css": "./dist/styles/tokens.css",
    "./styles/index.css": "./dist/styles/index.css",
    "./styles/presets/brutalist.css": "./dist/styles/presets/brutalist.css",
    "./styles/presets/soft-pop.css": "./dist/styles/presets/soft-pop.css",
    "./styles/presets/tangerine.css": "./dist/styles/presets/tangerine.css",
    "./styles/*": "./dist/styles/*",
    "./ui": {
      "types": "./src/ui/index.ts",
      "import": "./src/ui/index.ts",
      "require": "./src/ui/index.ts",
      "default": "./src/ui/index.ts"
    },
    "./utils/auth-events": {
      "types": "./dist/utils/auth-events.d.ts",
      "import": "./dist/utils/auth-events.esm.js",
      "require": "./dist/utils/auth-events.cjs.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist && tsc --emitDeclarationOnly --outDir dist/utils src/utils/auth-events.ts --declaration --declarationMap --esModuleInterop --skipLibCheck && cp -r src/styles dist/styles",
    "dev": "vite",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@auth0/auth0-react": "^2.0.0",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-checkbox": "^1.1.0",
    "@radix-ui/react-collapsible": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.0",
    "@radix-ui/react-radio-group": "^1.2.0",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "cmdk": "^1.0.0",
    "react-hook-form": "^7.0.0",
    "@types/react": "^19.0.0",
    "class-variance-authority": "^0.7.0",
    "lucide-react": "^0.400.0",
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0",
    "sonner": "^2.0.0",
    "next": "^13.0.0 || ^14.0.0 || ^15.0.0 || ^16.0.0"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "react-hook-form": {
      "optional": true
    }
  },
  "devDependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-collapsible": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.1.7",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "cmdk": "^1.0.0",
    "react-hook-form": "^7.66.1",
    "class-variance-authority": "^0.7.1",
    "lucide-react": "^0.577.0",
    "sonner": "^2.0.7",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@auth0/auth0-react": "^2.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "@types/jest": "^27.5.2",
    "@types/node": "^20.19.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.0",
    "globals": "^15.0.0",
    "jsdom": "^27.4.0",
    "next": "^16.0.0",
    "pino-pretty": "^13.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.6",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "react",
    "typescript",
    "components",
    "utilities"
  ],
  "author": "Company Team",
  "license": "MIT",
  "dependencies": {
    "pino": "^10.2.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^3.4.0"
  }
}
